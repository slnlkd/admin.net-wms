		{
			"name": "1. CreateOrder - 入库单据下发",
			"item": [
				{
					"name": "✅ 正常场景-有效的入库单据下发",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"Id\": 9100000000600102,\n  \"ReceivingDock\": \"TEST_PDA-PORT01\",\n  \"NetWeight\": \"50.5\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/WmsPort/CreateOrder",
							"host": ["{{baseUrl}}"],
							"path": ["api", "WmsPort", "CreateOrder"]
						},
						"description": "使用有效的入库单据明细ID进行下发"
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"状态码为200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"响应包含Success字段\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('Success');",
									"});",
									"",
									"pm.test(\"Success为true\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.Success).to.be.true;",
									"});",
									"",
									"pm.test(\"Data包含订单信息\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.Data).to.have.property('BillCode');",
									"    pm.expect(jsonData.Data).to.have.property('GoodCode');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					]
				},
				{
					"name": "✅ 正常场景-不同入库口",
