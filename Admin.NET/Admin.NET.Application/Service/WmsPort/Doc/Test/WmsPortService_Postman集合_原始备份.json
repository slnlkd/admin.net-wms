						},
						"url": {
							"raw": "{{baseUrl}}/api/WmsPort/CreateImportOrder",
							"host": ["{{baseUrl}}"],
							"path": ["api", "WmsPort", "CreateImportOrder"]
						},
						"description": "托盘申请入库到立体库，系统自动分配最优库位"
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"状态码为200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Code为1(成功)\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.Code).to.eql(1);",
									"});",
									"",
									"pm.test(\"Data包含任务信息\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.Data).to.be.an('array');",
									"    pm.expect(jsonData.Data.length).to.be.above(0);",
									"    pm.expect(jsonData.Data[0]).to.have.property('TaskNo');",
									"    pm.expect(jsonData.Data[0]).to.have.property('TaskMode');",
									"    pm.expect(jsonData.Data[0].TaskMode).to.eql(1);",
									"});"
