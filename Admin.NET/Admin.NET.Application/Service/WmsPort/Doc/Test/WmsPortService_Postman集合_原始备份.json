{
	"info": {
		"_postman_id": "wmsport-complete-test-collection-v2",
		"name": "WmsPortService完整测试集 v2.0（真实数据版）",
		"description": "WmsPortService所有接口的全业务场景测试集合 - 使用数据库真实数据\n\n包含7个接口，共45+测试场景\n- CreateOrder: 入库单据下发\n- CreateImportOrder: 入库申请\n- CreateImportOrder2: 二次入库申请\n- TaskFeedback: 任务反馈\n- GenerateGroupPallets: 组托反馈\n- KBackConfirm: 空载具组盘\n- AddOutPalno: 空载具申请\n\n每个接口包含成功场景和失败场景的完整测试用例。\n所有测试数据均来自数据库真实查询结果。",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "wmsport-api-tester"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{token}}",
				"type": "string"
			}
		]
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:5005",
			"type": "string"
		},
		{
			"key": "token",
			"value": "your-token-here",
			"type": "string"
		}
	],
